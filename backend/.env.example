# ============================================================
# Backend Environment Variables
# cp .env.example .env && nano .env
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://deprem_user:YOUR_DB_PASSWORD@deprem_db:5432/deprem_db

# Redis
REDIS_URL=redis://deprem_redis:6379/0

# JWT — oluştur: openssl rand -hex 32
SECRET_KEY=YOUR_SECRET_KEY_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Twilio (SMS/WhatsApp - Acil Kisiler)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI (Whisper - S.O.S Voice)
OPENAI_API_KEY=

# Anthropic Claude (NLP - S.O.S Voice)
ANTHROPIC_API_KEY=

# CORS
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000

# Debug
DEBUG=false
