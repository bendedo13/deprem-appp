# ============================================================
# Backend Environment Variables
# cp .env.example .env && nano .env
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://deprem_user:YOUR_DB_PASSWORD@deprem_db:5432/deprem_db

# Redis
REDIS_URL=redis://deprem_redis:6379/0

# JWT — oluştur: openssl rand -hex 32
SECRET_KEY=YOUR_SECRET_KEY_HERE
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Firebase Admin SDK (Push Notifications + Google Sign-In Token Doğrulama)
# Service Account JSON'dan kopyalayın: Firebase Console → Proje Ayarları → Hizmet Hesapları → Yeni özel anahtar oluştur
FIREBASE_PROJECT_ID=depremapp-29518
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Opsiyonel — Service Account JSON'daki "private_key_id" alanı
FIREBASE_PRIVATE_KEY_ID=
# Opsiyonel — Service Account JSON'daki "client_id" alanı
FIREBASE_CLIENT_ID=
# Alternatif: JSON dosyasını doğrudan kullanmak için (yukarıdaki env'lere gerek kalmaz)
# FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# Twilio (SMS/WhatsApp - Acil Kisiler)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI (Whisper - S.O.S Voice) — artık kullanılmıyor, Groq kullanılıyor
# OPENAI_API_KEY=

# Groq (S.O.S ses → metin, whisper-large-v3)
GROQ_API_KEY=

# Anthropic Claude (NLP - S.O.S Voice)
ANTHROPIC_API_KEY=

# CORS
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000

# Debug
DEBUG=false
