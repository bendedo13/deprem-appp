# ============================================================
# QuakeSense Production Environment Variables
# cp .env.production.example .env && nano .env
# ============================================================

# Database (ZORUNLU)
DB_PASSWORD=BURAYA_GUCLU_SIFRE_KOYUN

# Application Secret (ZORUNLU) — oluştur: openssl rand -hex 32
SECRET_KEY=BURAYA_OPENSSL_RAND_HEX_32_CIKTISI

# Frontend API URL
VITE_API_URL=https://deprem.quakesense.com/api/v1

# CORS — virgülle ayrılmış izinli origin'ler
ALLOWED_ORIGINS=https://deprem.quakesense.com

# Firebase Push Notifications (opsiyonel)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Twilio SMS (opsiyonel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI Whisper (opsiyonel — SOS sesli mesaj)
OPENAI_API_KEY=

# Anthropic Claude (opsiyonel — SOS NLP)
ANTHROPIC_API_KEY=
