# ════════════════════════════════════════════
# Deprem App — Deploy Ortam Değişkenleri
# Bu dosyayı deploy/.env olarak kopyalayın:
#   cp .env.example .env
#   nano .env
# ════════════════════════════════════════════

# Sunucu IP adresi veya domain (frontend API URL için)
# Örnek: SERVER_IP=46.4.123.77
# Örnek: SERVER_IP=deprem.siteniz.com
SERVER_IP=SUNUCU_IP_ADRESI

# Veritabanı şifresi (güçlü ve benzersiz olmalı)
DB_PASSWORD=güçlü_bir_şifre_buraya

# JWT Secret Key (en az 32 karakter, rastgele)
SECRET_KEY=uzun_rastgele_bir_string_en_az_32_karakter
