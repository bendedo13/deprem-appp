{
  "expo": {
    "name": "QuakeSense: Deprem Uyarı ve Takip",
    "slug": "quakesense",
    "version": "1.0.0",
    "description": "QuakeSense, deprem anında en hızlı ve güvenilir bilgiye ulaşmanız için geliştirilmiş hayat kurtaran bir platformdur.",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#230f0f"
    },
    "extra": {
      "apiUrl": "http://46.4.123.77:8001"
    },
    "plugins": [
      "expo-sensors",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Konum, deprem sinyali göndermek için kullanılır."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "S.O.S sesli mesaj göndermek için mikrofon izni gereklidir."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 23,
            "kotlinVersion": "1.9.0"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1173265458993328~5191916494"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "android": {
      "package": "com.quakesense",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#230f0f"
      },
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "com.quakesense",
      "supportsTablet": true
    }
  }
}
