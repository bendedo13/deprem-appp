{
  "expo": {
    "name": "QuakeSense: Life-Saving Tracker",
    "slug": "quakesense",
    "version": "1.1.0",
    "description": "QuakeSense is the ultimate life-saving technology designed to track global seismic activities with unprecedented speed and reliability.",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e17"
    },
    "extra": {
      "apiUrl": "http://46.4.123.77:8001",
      "googleWebClientId": "775124568904-flr9bo452no12v9giofdlb743m8gvqk4.apps.googleusercontent.com"
    },
    "plugins": [
      "./plugins/withNotifeeAndroidFix",
      "expo-sensors",
      "expo-notifications",
      "expo-task-manager",
      "expo-background-fetch",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Konum, deprem sinyali gondermek icin kullanilir.",
          "locationAlwaysPermission": "Arka planda deprem uyarilari icin konum izni gereklidir."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "S.O.S sesli mesaj gondermek icin mikrofon izni gereklidir."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 23,
            "kotlinVersion": "1.9.0",
            "buildToolsVersion": "34.0.0"
          }
        }
      ],
      [
        "./plugins/withGoogleMobileAds",
        {
          "androidAppId": "ca-app-pub-1173265458993328~5191916494",
          "iosAppId": "ca-app-pub-1173265458993328~5191916494"
        }
      ]
    ],
    "android": {
      "package": "com.quakesense",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0e17"
      },
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "bundleIdentifier": "com.quakesense",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Deprem aninda konumunuz acil kisilerinize iletilir.",
        "NSLocationAlwaysUsageDescription": "Arka planda deprem uyarilari icin konum izni gereklidir."
      }
    }
  }
}
