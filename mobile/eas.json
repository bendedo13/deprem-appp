{
    "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
                "EXPO_PUBLIC_API_URL": "http://46.4.123.77:8001"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            },
            "env": {
                "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
                "EXPO_PUBLIC_API_URL": "http://46.4.123.77:8001"
            }
        },
        "production": {
            "distribution": "store",
            "android": {
                "buildType": "app-bundle"
            },
            "node": "18.19.1",
            "env": {
                "EAS_BUILD_NO_EXPO_GO_WARNING": "true",
                "EXPO_PUBLIC_API_URL": "https://deprem-api.quakesense.com"
            },
            "cache": {
                "key": "production-v5",
                "paths": [
                    ".expo"
                ]
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./google-play-service-account.json",
                "track": "internal"
            }
        }
    }
}
