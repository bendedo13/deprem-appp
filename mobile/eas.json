{
    "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "node": "18.18.0",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
            }
        },
        "preview": {
            "distribution": "internal",
            "node": "18.18.0",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            },
            "env": {
                "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
            }
        },
        "production": {
            "node": "18.18.0",
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease"
            },
            "env": {
                "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
            }
        }
    },
    "submit": {
        "production": {
            "android": {
                "serviceAccountKeyPath": "./google-play-service-account.json",
                "track": "internal"
            }
        }
    }
}